schema target_index {
    document target_index {
        field embedding type tensor<float>(x[768]) {
            indexing: summary | attribute | index
            attribute {
                # innerproduct is the correct metric for unnormalized cohere
                # embeddings (norms ~12-15, NOT unit vectors).
                # prenormalized-angular was tested (2026-04-14) and produced
                # identical 0.76 recall — confirming the recall gap vs
                # OS/Milvus (0.97) is Vespa's HNSW exploration depth, not
                # the distance function.
                distance-metric: innerproduct
            }
            index {
                hnsw {
                    max-links-per-node: 16
                    neighbors-to-explore-at-insert: 200
                }
            }
        }
    }

    rank-profile vector-similarity {
        inputs {
            query(query_vector) tensor<float>(x[768])
        }
        first-phase {
            expression: closeness(field, embedding)
        }
    }
}
